## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# VS Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
CompileLog.txt

# Visual Studio Analyzer
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Profiling Tool
_Chm64_HP_*.vsp

# Developer Express CodeRush
*.crwl

# SAK (Source Code Control) files
*.sak

# Microsoft Azure Build Output
csx/
*.build.csdef

# Visual Studio Backup Files
*.bak
*.cache
*.ilk
*.log
*.pdb
*.sbr
*.scc
*.tlog

# Visual Studio Precompiled Header Files
*.pch

# Visual Studio Embedded Manifest Files
*.embed.manifest

# Visual Studio Resource Editor Temporary Files
*.res

# Visual Studio Search Engine Index
*.sdf

# Visual Studio IntelliSense
*.ipch
*.opendb

# Visual Studio Memory Dump Files
*.dmp

# Visual Studio Web Tooling
.eslintcache
.stylelintcache
node_modules/
bower_components/

# Visual Studio ClickOnce
*.application
*.manifest
*.deploy

# Visual Studio Installer Projects
*.vdproj

# Visual Studio Version Control Files
_Chm64_HP_*.vsp

# Rider
.idea/

# OS specific files
.DS_Store
Thumbs.db
desktop.ini

# App specific

